{
  "$schema": "https://modelcontextprotocol.io/schemas/server.schema.json",
  "name": "alphafold-sovereign-mcp",
  "version": "1.1.9",
  "description": "MCP server wrapping AlphaFold DB and 8 other biomedical data sources behind a set of MCP tool calls; persists each result to a local SQLite knowledge graph for later querying.",
  "vendor": "Santiago Maniches",
  "license": "Apache-2.0",
  "homepage": "https://github.com/smaniches/alphafold-sovereign-mcp",
  "documentation": "https://smaniches.github.io/alphafold-sovereign-mcp/",
  "repository": {
    "type": "git",
    "url": "https://github.com/smaniches/alphafold-sovereign-mcp.git"
  },
  "issues": "https://github.com/smaniches/alphafold-sovereign-mcp/issues",
  "doi": "10.5281/zenodo.20134773",
  "protocol_version": "2025-06-18",
  "transports": [
    {
      "type": "stdio",
      "command": "alphafold-sovereign-mcp"
    }
  ],
  "capabilities": {
    "tools": {
      "listChanged": true
    },
    "resources": false,
    "prompts": false,
    "logging": false
  },
  "categories": [
    "bioinformatics",
    "scientific-research",
    "knowledge-base"
  ],
  "tags": [
    "alphafold",
    "uniprot",
    "open-targets",
    "chembl",
    "clinvar",
    "gnomad",
    "ensembl",
    "rcsb-pdb",
    "interpro",
    "mondo",
    "hpo",
    "disgenet",
    "gene-ontology",
    "human-protein-atlas",
    "variant-classification",
    "drug-discovery",
    "knowledge-graph"
  ],
  "maturity": "beta",
  "status_note": "v1.1.9 — engineering-validated (689 tests, 100% line and branch coverage). Scientific outputs (ACMG draft, druggability tier) have NOT been validated by independent domain experts. Not yet deployed in production. See STATUS.md and LIMITATIONS.md.",
  "install": {
    "pypi": {
      "name": "alphafold-sovereign-mcp",
      "url": "https://pypi.org/project/alphafold-sovereign-mcp/",
      "command": "pip install alphafold-sovereign-mcp"
    },
    "from_source": {
      "command": "git clone https://github.com/smaniches/alphafold-sovereign-mcp && cd alphafold-sovereign-mcp && uv pip install -e ."
    },
    "verify": "alphafold-sovereign --self-test"
  }
}
